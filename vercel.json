{
  "framework": "vite",
  "images": {
    "sizes": [256, 384, 640, 750, 828, 1080, 1200, 1920],
    "formats": ["image/avif", "image/webp"],
    "minimumCacheTTL": 2592000,
    "remotePatterns": [
      {
        "protocol": "https",
        "hostname": "**.public.blob.vercel-storage.com"
      }
    ]
  },
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/fonts/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/_vercel/image(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=2592000, s-maxage=2592000, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, s-maxage=300, stale-while-revalidate=600"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/ai/generate", "destination": "/api/ai/generate" },
    { "source": "/api/:path*", "destination": "https://gradexhibit.tech/api/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
